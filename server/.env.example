# ============================================
# Database Configuration
# ============================================
# Choose dialect: 'mysql' or 'postgres' (postgres recommended for Render)
DB_DIALECT=postgres

# --- PostgreSQL (recommended for Render free tier) ---
DB_HOST=your-postgres-host.render.com
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
DB_SSL=true

# --- MySQL (if using an external MySQL service) ---
# DB_HOST=your-mysql-host.com
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=bookstore

# ============================================
# Server Configuration
# ============================================
PORT=5000
JWT_SECRET=your_jwt_secret_key_here_minimum_32_chars

# ============================================
# Email Configuration
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=BookStore <noreply@bookstore.com>

# Client URL for email links
CLIENT_URL=http://localhost:5173
